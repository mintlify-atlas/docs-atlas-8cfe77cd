  "keyFeatures": [
    "Telegram WebApp integration with seamless user authentication",
    "Real-time multiplayer game rooms using WebSocket (Flask-SocketIO)",
    "Virtual currency (Bits) system with betting and winnings tracking",
    "Three casino games: Slot Machine, Moche card game, and French Roulette",
    "Admin dashboard for user and currency management",
    "Leaderboard system for top players and winners"
  ],
  "publicApiSurface": [
    "/register - Register Telegram user",
    "/bet - Place bet and deduct bits",
    "/win - Award winning bits to user",
    "/api/rooms - Create and list multiplayer rooms",
    "/slotmachine - Slot machine game interface",
    "/moche - Moche card game with multiplayer support",
    "/ruleta - French roulette game interface",
    "/admin - Admin panel for user management",
    "join_moche_room - WebSocket event to join a multiplayer room",
    "toggle_ready - WebSocket event to toggle player ready state",
    "start_moche_game - WebSocket event to start the game",
    "sync_state - WebSocket event to synchronize game state"
  ]
